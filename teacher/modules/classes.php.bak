<?php
// teacher/classes.php — teacher's assigned classes/subjects using subject_teachers + subject_classes (simple navigation links)
session_start();
require_once __DIR__ . '/../../includes/db.php';

// Auth check
if (!isset($_SESSION['user_id']) || ($_SESSION['role'] ?? '') !== 'Teacher') {
    header('Location: ../auth/login.php?error=Please+login+as+Teacher');
    exit;
}
$user_id = (int)$_SESSION['user_id'];

// Get teacher details
$teacher = null;
if ($stmt = $conn->prepare("SELECT id, first_name, last_name, username FROM teachers WHERE user_id = ? LIMIT 1")) {
    $stmt->bind_param('i', $user_id);
    $stmt->execute();
    $teacher = $stmt->get_result()->fetch_assoc();
    $stmt->close();
}
$teacherId = (int)($teacher['id'] ?? $user_id);
$teacherName = trim(($teacher['first_name'] ?? '') . ' ' . ($teacher['last_name'] ?? '')) ?: 'Teacher';

// Fetch assigned subjects/classes
$sql = "SELECT 
            c.id AS class_id,
            c.class_name,
            s.id AS subject_id,
            s.name AS subject_name
        FROM subject_teachers st
        INNER JOIN subject_classes sc ON st.subject_id = sc.subject_id
        INNER JOIN classes c ON sc.class_id = c.id
        INNER JOIN subjects s ON st.subject_id = s.id
        WHERE st.teacher_id = ?
        ORDER BY c.class_name, s.name";
$stmt = $conn->prepare($sql);
$stmt->bind_param('i', $teacherId);
$stmt->execute();
$res = $stmt->get_result();
$assignments = $res->fetch_all(MYSQLI_ASSOC);
$stmt->close();

// Get student counts per class
$classCounts = [];
if (!empty($assignments)) {
    $classIds = array_column($assignments, 'class_id');
    $in = implode(',', array_map('intval', array_unique($classIds)));
    $countRes = $conn->query("SELECT class_id, COUNT(*) AS total FROM students WHERE class_id IN ($in) GROUP BY class_id");
    while ($row = $countRes->fetch_assoc()) {
        $classCounts[$row['class_id']] = $row['total'];
    }
}
?>

<!doctype html>

