<div class="container-fluid p-4">

  <div class="page-header">
    <div>
      <h4 class="mb-0">My Assigned Classes</h4>
      <small class="text-muted"><?= htmlspecialchars($teacherName) ?></small>
    </div>
    <a href="dashboard.php" class="btn btn-outline-primary btn-sm">
      <i class="fa fa-arrow-left me-1"></i> Back to Dashboard
    </a>
  </div>

  <?php if (empty($assignments)): ?>


<div class="alert alert-info">No assigned classes or subjects found.</div>

  <?php else: ?>


<div class="row g-3">
  <?php foreach ($assignments as $a): 
    $cid = (int)$a['class_id'];
    $sid = (int)$a['subject_id'];
    $count = $classCounts[$cid] ?? 0;
  ?>
    <div class="col-sm-6 col-lg-4">
      <div class="card class-card p-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <h5 class="mb-0"><?= htmlspecialchars($a['class_name']) ?></h5>
          <span class="subject-badge"><?= htmlspecialchars($a['subject_name']) ?></span>
        </div>
        <div class="student-count">
          <i class="fa fa-users me-1"></i> <?= $count ?> student<?= $count == 1 ? '' : 's' ?>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <a href="enter_scores.php?class_id=<?= $cid ?>&subject_id=<?= $sid ?>" class="btn btn-sm btn-outline-primary">
            <i class="fa fa-pen"></i> Enter Marks
          </a>
          <a href="view_students.php?class_id=<?= $cid ?>" class="btn btn-sm btn-outline-secondary">
            <i class="fa fa-user-graduate"></i> View Students
          </a>
          <a href="reports.php?class_id=<?= $cid ?>&subject_id=<?= $sid ?>" class="btn btn-sm btn-outline-success">
            <i class="fa fa-file-alt"></i> Reports
          </a>
        </div>
      </div>
    </div>
  <?php endforeach; ?>
</div>


  <?php endif; ?>

</div>

