<?php include __DIR__ . '/../../admin/partials/footer_stub.php'; ?>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
$(function(){
  const $rows = $('#studentsTable tbody tr');

  // Filter by class
  $('#classFilter').on('change', function(){
    const val = $(this).val().toLowerCase();
    $rows.show().filter(function(){
      return val && $(this).data('class').toLowerCase() !== val;
    }).hide();
  });

  // Search filter
  $('#studentSearch').on('keyup', function(){
    const val = $(this).val().toLowerCase();
    $rows.show().filter(function(){
      return !$(this).text().toLowerCase().includes(val);
    }).hide();
  });

  // Sort buttons
  $('.sort-btn').on('click', function(){
    const order = $(this).data('sort');
    const sorted = $rows.sort((a,b)=>{
      const nameA = $(a).find('td:nth-child(2)').text().toLowerCase();
      const nameB = $(b).find('td:nth-child(2)').text().toLowerCase();
      return order === 'asc' ? nameA.localeCompare(nameB) : nameB.localeCompare(nameA);
    });
    $('#studentsTable tbody').html(sorted);
  });
});
</script>


</body>
</html>
