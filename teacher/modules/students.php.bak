<div class="container-fluid p-4">

  <div class="page-header">
    <div>
      <h4 class="mb-0">All My Students</h4>
      <small class="text-muted">Taught by <?= htmlspecialchars($teacherName) ?></small>
    </div>
    <a href="dashboard.php" class="btn btn-outline-primary btn-sm">
      <i class="fa fa-arrow-left me-1"></i> Back to Dashboard
    </a>
  </div>

  <?php if (empty($students)): ?>


<div class="alert alert-info">No students found for your assigned classes.</div>


  <?php else: ?>

  <div class="card">
    <div class="card-body">
      <div class="filter-bar">
        <div class="input-group" style="max-width:300px;">
          <span class="input-group-text bg-light"><i class="fa fa-filter text-primary"></i></span>
          <select id="classFilter" class="form-select">
            <option value="">All Classes</option>
            <?php foreach ($classes as $c): ?>
              <option value="<?= $c['class_name'] ?>"><?= htmlspecialchars($c['class_name']) ?></option>
            <?php endforeach; ?>
          </select>
        </div>


    <div class="input-group" style="max-width:300px;">
      <span class="input-group-text bg-light"><i class="fa fa-search text-primary"></i></span>
      <input id="studentSearch" type="text" class="form-control" placeholder="Search students...">
    </div>

    <div class="ms-auto">
      <button class="btn btn-outline-secondary btn-sm sort-btn" data-sort="asc"><i class="fa fa-sort-alpha-down"></i> Sort A–Z</button>
      <button class="btn btn-outline-secondary btn-sm sort-btn" data-sort="desc"><i class="fa fa-sort-alpha-up"></i> Sort Z–A</button>
    </div>
  </div>

  <div class="table-responsive">
    <table id="studentsTable" class="table table-striped table-bordered align-middle">
      <thead>
        <tr>
          <th>#</th>
          <th>Full Name</th>
          <th>Gender</th>
          <th>Admission No.</th>
          <th>Class</th>
        </tr>
      </thead>
      <tbody>
        <?php $i=1; foreach ($students as $s): ?>
          <tr data-class="<?= htmlspecialchars($s['class_name']) ?>">
            <td><?= $i++ ?></td>
            <td><?= htmlspecialchars($s['first_name'].' '.$s['last_name']) ?></td>
            <td><?= htmlspecialchars($s['gender']) ?></td>
            <td><?= htmlspecialchars($s['admission_no']) ?></td>
            <td><?= htmlspecialchars($s['class_name']) ?></td>
          </tr>
        <?php endforeach; ?>
      </tbody>
    </table>
  </div>
</div>

  </div>
  <?php endif; ?>
